    ]
    let mut alloc = std.mem.fixedBufAlloc(storage)
    
    // Read file content
    let content_maybe = std.fs.readAll(alloc, fs, filename, 4096)
    
    if content_maybe.has == false {
        check world.err.write("Error: Could not read file (too large or I/O error)\n")
        raise TooLarge
    }
    
    let mut content_buf: owned<ByteBuf> = content_maybe.value
    let bytes = std.mem.bufBytes(&content_buf)
    
    // Compute checksums
    let crc32 = std.codec.crc32Bytes(bytes)
    let crypto_hash = std.crypto.hash32(bytes)
    
    // Output results
    check world.out.write("File: ")
    check world.out.write(filename)
    check world.out.write("\n")
    
    check formatChecksum(&world, "CRC32", crc32)
    check formatChecksum(&world, "Hash32", crypto_hash)
    
    check world.out.write("\nChecksum computation completed successfully.\n")
}

