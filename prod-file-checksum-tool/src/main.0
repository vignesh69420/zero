// Production File Checksum Tool
// Real-world CLI for computing file checksums
// Usage: checksum-cli <filename>

use formatter

pub fun main(world: World) -> Void raises { NotFound, TooLarge, Io } {
    let fs = std.fs.host()
    
    // Get filename from arguments
    let arg = std.args.get(1)
    if arg.has == false {
        check world.err.write("Usage: checksum-cli <filename>\n")
        check world.err.write("Example: checksum-cli README.md\n")
        return
    }
    
    let filename = arg.value
    
    // Check if file exists
    if std.fs.exists(filename) == false {
        check world.err.write("Error: File not found: ")
        check world.err.write(filename)
        check world.err.write("\n")
        raise NotFound
    }
    
