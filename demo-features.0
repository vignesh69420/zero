// Zero Language Features Demo

// Feature 1: Functions and integer arithmetic
fun add_numbers(a: i32, b: i32) -> i32 {
    return a + b
}

// Feature 2: Integer types and casting
fun integer_types() -> i32 {
    let count: u32 = 42_u32
    let converted: i32 = count as i32
    return converted
}

// Feature 3: Explicit error handling
fun might_fail(ok: Bool) -> i32 raises { CustomError } {
    if ok == false {
        raise CustomError
    }
    return 42
}

// Feature 4: Control flow with if/else
fun check_value(value: i32) -> i32 {
    if value == 42 {
        return 1
    } else {
        if value > 42 {
            return 2
        } else {
            return 0
        }
    }
}

// Feature 5: Loops with mutable variables
fun count_down(start: i32) -> i32 {
    let mut counter = start
    while counter > 0 {
        counter = counter - 1
    }
    return counter
}

// Feature 6: Boolean logic
fun logic_demo() -> i32 {
    let a = true
    let b = false
    if a && b == false {
        return 1
    }
    return 0
}

// Main - demonstrates capability-based I/O
pub fun main(world: World) -> Void raises {
    check world.out.write("=== Zero Language Demo ===\n\n")
    
    check world.out.write("1. Functions & arithmetic: ")
    if add_numbers(40, 2) == 42 {
        check world.out.write("PASS\n")
    }
    
    check world.out.write("2. Integer types & casting: ")
    if integer_types() == 42 {
        check world.out.write("PASS\n")
    }
    
    check world.out.write("3. Error handling: ")
    check might_fail(true)
    check world.out.write("PASS\n")
    
    check world.out.write("4. Control flow: ")
    if check_value(42) == 1 {
        check world.out.write("PASS\n")
    }
    
    check world.out.write("5. Loops & mutation: ")
    if count_down(5) == 0 {
        check world.out.write("PASS\n")
    }
    
    check world.out.write("6. Boolean logic: ")
    if logic_demo() == 1 {
        check world.out.write("PASS\n")
    }
    
    check world.out.write("\nAll tests passed!\n")
}

